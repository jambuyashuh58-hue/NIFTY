# ─── TradePulse Environment Variables ────────────────────────────────────────
# 1. Copy this file and rename it to .env.local
#    Run: cp .env.example .env.local
#
# 2. Fill in your actual values below
# 3. NEVER push .env.local to GitHub — it's already in .gitignore ✓
# ─────────────────────────────────────────────────────────────────────────────


# ─── REQUIRED: Anthropic API Key ─────────────────────────────────────────────
# Used for the AI Strategy feature (morning brief, market analysis)
# Get your free key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-WITH-YOUR-KEY


# ─── AUTH: App Login Password ─────────────────────────────────────────────────
# The password you use to log in to TradePulse
# Change this to something strong before deploying!
APP_PASSWORD=tradepulse123


# ─── AUTH: Session Secret ─────────────────────────────────────────────────────
# A long random string used to secure your session cookie
# Generate one with: openssl rand -hex 32
SESSION_SECRET=replace-this-with-a-long-random-secret-string


# ─── OPTIONAL: App URL ───────────────────────────────────────────────────────
# Only needed for production deployment (e.g. on Vercel)
# Leave as localhost for local development
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── NOTE: WhatsApp Alerts ───────────────────────────────────────────────────
# No env variable needed here.
# Set up your WhatsApp number and CallMeBot API key inside the app:
# TradePulse → Settings → WhatsApp Alerts
